{
  "name": "@bambora/checkout-sdk-web",
  "version": "3.2.1",
  "description": "JavaScript SDK for Checkout.",
  "main": "./dist/checkout-sdk.js",
  "module": "./dist/checkout-sdk.mjs",
  "types": "./dist/types/index.d.ts",
  "engines": {
    "node": ">=22.22.2"
  },
  "scripts": {
    "start": "rimraf ./dist && rollup -c --configPlugin typescript --watch",
    "clean": "rimraf ./dist",
    "build": "npm run lint && npm run clean && rollup -c --configPlugin typescript",
    "build:production": "cross-env NODE_ENV=production npm run build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "web-test-runner",
    "test:package": "tsx test/test-package.ts",
    "test:package:clean": "rimraf --glob ./bambora-checkout-sdk-web-*.tgz",
    "test:all": "npm run build && npm run test && npm run test:package && npm run test:package:clean"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bambora/checkout-sdk-web.git"
  },
  "author": "Worldline S.A. <support.nordics@worldline.com> (https://worldline.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bambora/checkout-sdk-web/issues"
  },
  "homepage": "https://github.com/bambora/checkout-sdk-web#readme",
  "browserslist": [
    "IE 11",
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "overrides": {
    "glob": "13.0.6",
    "mocha": {
      "diff": "8.0.4",
      "serialize-javascript": "7.0.5"
    }
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@types/node": "25.6.0",
    "@types/sinon": "21.0.1",
    "@web/dev-server-esbuild": "1.0.5",
    "@web/test-runner": "0.20.2",
    "@web/test-runner-mocha": "0.9.0",
    "chai": "6.2.2",
    "cross-env": "10.1.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-node": "0.3.10",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-compat": "7.0.2",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-prettier": "5.5.5",
    "mitt": "3.0.1",
    "mocha": "11.7.5",
    "promise-polyfill": "8.3.0",
    "rimraf": "6.1.3",
    "rollup": "4.60.3",
    "sinon": "22.0.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2"
  }
}
