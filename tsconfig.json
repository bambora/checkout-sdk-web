{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "node",
    "target": "es5",
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationDir": "./dist/types",
    "inlineSourceMap": false,
    "alwaysStrict": true,
    "removeComments": true,
    "strict": true,
    "lib": ["dom", "es5", "es2015"],
    "noImplicitAny": false,
    "isolatedModules": true,
  },
  "include": ["src/**/*"]
}
